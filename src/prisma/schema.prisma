generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma_client"
  binaryTargets = ["native", "windows", "linux-musl-openssl-3.0.x", "darwin-arm64"]
}

datasource db {
  provider = "postgresql"
}

///  * ---------------- USERS & ROLES ----------------
model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  emailVerified Boolean        @default(false)
  image         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now()) @updatedAt
  accounts      Account[]
  registrations Registration[]
  sessions      Session[]

  @@map("user")
}

/// *
///  * ---------------- REGISTRATIONS ----------------
model Registration {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?
  participants Int      @default(1)
  createdAt    DateTime @default(now())
  eventId      String
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])

  @@map("registration")
}

/// *
///  * ---------------- SESSIONS & ACCOUNTS ----------------
model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now()) @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model Clients {
  id   String @id @default(cuid())
  name String

  email      String? @unique
  phone      String?
  company    String?
  address    String?
  city       String?
  postalCode String?
  country    String? @default("France")

  siret     String? @unique
  vatNumber String?

  dailyRate Float? // TJM (Taux Journalier Moyen)
  isActive  Boolean   @default(true)
  startDate DateTime?
  endDate   DateTime?

  activities        activity[]
  inviteLinks InviteLink[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  invoices  Invoice[]

  @@index([name])
  @@index([company])
}

model activity {
  id String @id @default(cuid())

  clientId String
  client   Clients @relation(fields: [clientId], references: [id], onDelete: Cascade)

  date  DateTime
  month Int
  year  Int

  daysWorked  Float
  hoursWorked Float?
  description String?

  validatedAt     DateTime?
  rejectedAt      DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  invoices Invoice[]

  @@index([clientId])
  @@index([month, year])
}

model InviteLink {
  id        String   @id @default(cuid())
  clientId  String
  token     String   @unique // ex: random 32 chars ou UUID v4
  expiresAt DateTime
  used      Boolean  @default(false)
  createdBy String // userId de l'admin qui a créé le lien
  client    Clients  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([clientId])
  @@map("client_invite")
}

model Invoice {
  id        String        @id @default(cuid())
  craId     String
  clientId  String
  amountHT  Float
  amountTTC Float
  tvaRate   Float         @default(20.0)
  tvaAmount Float
  status    InvoiceStatus
  number    String        @unique // ex: FACT-2026-001
  issuedAt  DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  activity    activity?    @relation(fields: [craId], references: [id])
  client Clients @relation(fields: [clientId], references: [id])

  @@index([clientId, issuedAt])
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
}
